# ─── Client-side (safe to ship in bundle — these are public Firebase config) ───
# These values are NOT secret. They identify your Firebase project to the SDK.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_APP_ID=
VITE_API_BASE_URL=https://ffe-api.<your-worker>.workers.dev

# ─── Server-side ONLY ─────────────────────────────────────────────────────────
# NEVER prefix these with VITE_. NEVER import them in /src (React/Vite code).
# Set these in Cloudflare Worker secrets via: wrangler secret put <VAR_NAME>
NEON_DATABASE_URL=
FIREBASE_ADMIN_PROJECT_ID=ffe-tool-auth
FIREBASE_ADMIN_CLIENT_EMAIL=
FIREBASE_ADMIN_PRIVATE_KEY=
